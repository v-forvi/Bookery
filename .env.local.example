# Biblio Environment Variables
# Copy this file to .env.local and fill in your values

# Database
# Path to SQLite database file (relative to project root)
DATABASE_URL="file:../../data/biblio.db"

# Vision API Keys
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-api-key-here"

# Vision API Preference
# Options: "claude" or "gemini"
PREFERRED_VISION_API="claude"

# Google Books API
# Uses free tier, no key required for basic usage
# For higher quotas, get key from: https://console.cloud.google.com/
GOOGLE_BOOKS_API_KEY=""
